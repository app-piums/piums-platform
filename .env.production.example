# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
POSTGRES_USER=piums_prod
POSTGRES_PASSWORD=CHANGEME_strong_production_password

# Database URLs for each service
AUTH_DATABASE_URL=postgresql://piums_prod:password@postgres:5432/piums_auth
USERS_DATABASE_URL=postgresql://piums_prod:password@postgres:5432/piums_users
ARTISTS_DATABASE_URL=postgresql://piums_prod:password@postgres:5432/piums_artists
CATALOG_DATABASE_URL=postgresql://piums_prod:password@postgres:5432/piums_catalog
BOOKING_DATABASE_URL=postgresql://piums_prod:password@postgres:5432/piums_booking
PAYMENTS_DATABASE_URL=postgresql://piums_prod:password@postgres:5432/piums_payments
REVIEWS_DATABASE_URL=postgresql://piums_prod:password@postgres:5432/piums_reviews
NOTIFICATIONS_DATABASE_URL=postgresql://piums_prod:password@postgres:5432/piums_notifications
SEARCH_DATABASE_URL=postgresql://piums_prod:password@postgres:5432/piums_search
CHAT_DATABASE_URL=postgresql://piums_prod:password@postgres:5432/piums_chat

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_PASSWORD=CHANGEME_strong_redis_password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:CHANGEME_strong_redis_password@redis:6379

# ============================================================================
# JWT & Authentication
# ============================================================================
JWT_SECRET=CHANGEME_minimum_32_characters_jwt_secret
REFRESH_SECRET=CHANGEME_minimum_32_characters_refresh_secret
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# ============================================================================
# CORS & Security
# ============================================================================
ALLOWED_ORIGINS=https://piums.com,https://www.piums.com,https://admin.piums.com
NODE_ENV=production

# ============================================================================
# Cloudinary (Avatar & Image Uploads)
# ============================================================================
CLOUDINARY_CLOUD_NAME=your_production_cloud_name
CLOUDINARY_API_KEY=your_production_api_key
CLOUDINARY_API_SECRET=CHANGEME_cloudinary_api_secret

# ============================================================================
# Stripe (Payments)
# ============================================================================
STRIPE_SECRET_KEY=sk_live_CHANGEME_stripe_live_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_CHANGEME_webhook_secret

# ============================================================================
# SMTP (Email Notifications)
# ============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=CHANGEME_sendgrid_api_key
SMTP_FROM=Piums <noreply@piums.com>

# ============================================================================
# SMS Provider (Twilio)
# ============================================================================
TWILIO_ACCOUNT_SID=CHANGEME_twilio_account_sid
TWILIO_AUTH_TOKEN=CHANGEME_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# Push Notifications (Firebase)
# ============================================================================
FCM_SERVER_KEY=CHANGEME_firebase_server_key
FCM_PROJECT_ID=your_firebase_project_id

# ============================================================================
# OAuth
# ============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=CHANGEME_google_client_secret
GOOGLE_CALLBACK_URL=https://piums.com/api/auth/google/callback

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=CHANGEME_facebook_app_secret
FACEBOOK_CALLBACK_URL=https://piums.com/api/auth/facebook/callback

# ============================================================================
# Service URLs (Internal Communication)
# ============================================================================
AUTH_SERVICE_URL=http://auth-service:4001
USERS_SERVICE_URL=http://users-service:4002
ARTISTS_SERVICE_URL=http://artists-service:4003
CATALOG_SERVICE_URL=http://catalog-service:4004
PAYMENTS_SERVICE_URL=http://payments-service:4005
REVIEWS_SERVICE_URL=http://reviews-service:4006
NOTIFICATIONS_SERVICE_URL=http://notifications-service:4007
BOOKING_SERVICE_URL=http://booking-service:4008
SEARCH_SERVICE_URL=http://search-service:4009
CHAT_SERVICE_URL=http://chat-service:4010

# ============================================================================
# Docker Registry
# ============================================================================
DOCKER_REGISTRY=ghcr.io/app-piums
IMAGE_TAG=latest

# ============================================================================
# Logging & Monitoring
# ============================================================================
LOG_LEVEL=warn
SENTRY_DSN=CHANGEME_sentry_production_dsn
SENTRY_ENVIRONMENT=production

# ============================================================================
# Rate Limiting (More restrictive in production)
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

# ============================================================================
# Backup Configuration
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
S3_BACKUP_BUCKET=piums-backups
AWS_ACCESS_KEY_ID=CHANGEME_aws_access_key
AWS_SECRET_ACCESS_KEY=CHANGEME_aws_secret_key

# ============================================================================
# SSL/TLS
# ============================================================================
SSL_CERT_PATH=/etc/ssl/certs/piums.crt
SSL_KEY_PATH=/etc/ssl/private/piums.key
