// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING           // Esperando confirmación del artista
  CONFIRMED         // Confirmada por el artista
  PAYMENT_PENDING   // Esperando pago del depósito
  PAYMENT_COMPLETED // Pago completado
  IN_PROGRESS       // En progreso (día de la cita)
  COMPLETED         // Completada exitosamente
  CANCELLED_CLIENT  // Cancelada por el cliente
  CANCELLED_ARTIST  // Cancelada por el artista
  REJECTED          // Rechazada por el artista
  NO_SHOW           // Cliente no se presentó
}

enum PaymentStatus {
  PENDING
  DEPOSIT_PAID      // Depósito pagado
  FULLY_PAID        // Totalmente pagado
  REFUNDED          // Reembolsado
  PARTIALLY_REFUNDED
}

model Booking {
  id          String   @id @default(uuid())
  
  // Relaciones con otros servicios
  clientId    String   // ID del usuario (users-service)
  artistId    String   // ID del artista (artists-service)
  serviceId   String   // ID del servicio contratado (catalog-service)
  
  // Información de la cita
  scheduledDate  DateTime  // Fecha y hora de la cita
  durationMinutes Int      // Duración en minutos
  location        String?  // Dirección de la cita
  locationLat     Float?
  locationLng     Float?
  
  // Estado
  status         BookingStatus @default(PENDING)
  statusHistory  BookingStatusChange[]
  
  // Pricing
  servicePrice   Int          // Precio del servicio en centavos
  addonsPrice    Int          @default(0) // Precio de addons en centavos
  totalPrice     Int          // Precio total en centavos
  currency       String       @default("MXN")
  
  depositRequired Boolean     @default(false)
  depositAmount   Int?        // Monto del depósito en centavos
  depositPaidAt   DateTime?
  
  paymentStatus   PaymentStatus @default(PENDING)
  paymentIntentId String?     // ID del Payment Intent de Stripe (payments-service)
  paidAmount      Int          @default(0)
  paidAt          DateTime?
  paymentMethod   String?
  
  // Add-ons contratados (array de IDs)
  selectedAddons  String[]
  
  // Notas
  clientNotes     String?      @db.Text
  artistNotes     String?      @db.Text
  internalNotes   String?      @db.Text // Notas para admin/staff
  
  // Cancelación
  cancelledAt     DateTime?
  cancelledBy     String?      // userId que canceló
  cancellationReason String?   @db.Text
  refundAmount    Int?         // Monto reembolsado en centavos
  
  // Confirmación
  confirmedAt     DateTime?
  confirmedBy     String?      // artistId
  
  // Recordatorios enviados
  reminderSent24h Boolean      @default(false)
  reminderSent2h  Boolean      @default(false)
  
  // Review (después de completar)
  reviewId        String?      @unique
  
  // Soft delete para auditorías
  deletedAt       DateTime?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@index([clientId])
  @@index([artistId])
  @@index([serviceId])
  @@index([status])
  @@index([scheduledDate])
  @@index([paymentStatus])
  @@map("bookings")
}

model BookingStatusChange {
  id          String   @id @default(uuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  fromStatus  BookingStatus?
  toStatus    BookingStatus
  changedBy   String   // userId o artistId que hizo el cambio
  reason      String?  @db.Text
  
  // Soft delete para auditorías
  deletedAt   DateTime?
  
  createdAt   DateTime @default(now())
  
  @@index([bookingId])
  @@index([createdAt])
  @@map("booking_status_changes")
}

// Disponibilidad bloqueada (para que artistas bloqueen días/horas específicas)
model BlockedSlot {
  id          String   @id @default(uuid())
  artistId    String
  
  startTime   DateTime
  endTime     DateTime
  
  reason      String?  @db.Text
  isRecurring Boolean  @default(false)
  
  // Soft delete para auditorías
  deletedAt   DateTime?
  
  createdAt   DateTime @default(now())
  
  @@index([artistId])
  @@index([startTime, endTime])
  @@map("blocked_slots")
}

// Configuración de disponibilidad del artista
model AvailabilityConfig {
  id                String   @id @default(uuid())
  artistId          String   @unique
  
  // Configuración de reserva
  minAdvanceHours   Int      @default(24)    // Mínimo de horas de anticipación
  maxAdvanceDays    Int      @default(90)    // Máximo de días de anticipación
  
  bufferMinutes     Int      @default(30)    // Tiempo de buffer entre citas
  
  autoConfirm       Boolean  @default(false) // Auto-confirmar reservas sin revisión
  requiresDeposit   Boolean  @default(true)
  
  // Política de cancelación
  cancellationHours Int      @default(48)    // Horas mínimas para cancelar sin penalización
  cancellationFee   Int      @default(0)     // Fee de cancelación en porcentaje (0-100)
  
  // Soft delete para auditorías
  deletedAt         DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("availability_configs")
}
