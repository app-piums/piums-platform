# Auth Service Environment Variables

# ===== CRITICAL: SEGURIDAD =====
# JWT Secret para firmar tokens de acceso (OBLIGATORIO en producción)
JWT_SECRET=your_super_secret_jwt_key_CHANGE_ME

# Refresh Token Secret (OBLIGATORIO en producción)
REFRESH_SECRET=your_super_secret_refresh_key_CHANGE_ME

# ===== BASE DE DATOS =====
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/piums_auth?schema=public

# ===== SERVIDOR =====
# Puerto del servicio
PORT=4001

# Entorno de ejecución (development | production | test)
NODE_ENV=development

# ===== LOGS =====
# Nivel de logs (error | warn | info | debug)
LOG_LEVEL=info

# ===== CORS =====
# URLs permitidas para CORS (separadas por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===== OAUTH - GOOGLE =====
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4001/auth/google/callback

# ===== OAUTH - FACEBOOK =====
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:4001/auth/facebook/callback

# ===== FRONTEND =====
# URL del frontend para redirects
FRONTEND_URL=http://localhost:3000

# URLs de las aplicaciones separadas (para redirección por rol)
CLIENT_APP_URL=http://localhost:3000
ARTIST_APP_URL=http://localhost:3001
ADMIN_APP_URL=http://localhost:3002

# ===== SESSION =====
# Secret para express-session
SESSION_SECRET=your_session_secret_CHANGE_ME
