// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PricingType {
  FIXED       // Precio fijo
  HOURLY      // Por hora
  PER_SESSION // Por sesión
  CUSTOM      // Personalizado / cotización
}

enum PricingModel {
  FIXED              // Precio fijo, sin variables
  BASE_PLUS_HOURLY   // Precio base + costo por hora/minuto adicional
  PACKAGE            // Paquete con minutos incluidos
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model ServiceCategory {
  id          String   @id @default(uuid())
  
  // Identificación
  name        String
  slug        String   @unique
  description String?  @db.Text
  icon        String?  // URL o nombre del icono
  image       String?  // Imagen/banner de la categoría
  
  // Jerarquía (categorías anidadas)
  parentId    String?
  parent      ServiceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subcategories ServiceCategory[] @relation("CategoryHierarchy")
  
  // Nivel en la jerarquía (0 = raíz, 1 = subcategoría, etc.)
  level       Int      @default(0)
  
  // Path completo de la categoría (ej: "arte/pintura/oleo")
  path        String?
  
  // Relación con servicios
  services    Service[]
  
  // Configuración y display
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  
  // SEO y metadatos
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  
  // Estadísticas
  serviceCount    Int      @default(0) // Número de servicios en esta categoría
  
  // Colores y branding
  primaryColor    String?  // Hex color primary
  secondaryColor  String?  // Hex color secondary
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([slug])
  @@index([parentId])
  @@index([path])
  @@index([level])
  @@index([isActive, isFeatured])
  @@map("service_categories")
}

model Service {
  id          String   @id @default(uuid())
  artistId    String   // Referencia al artista que ofrece este servicio
  
  // Información básica
  name        String
  slug        String
  description String   @db.Text
  
  // Categoría
  categoryId  String
  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  
  // Ubicación (si el servicio es local/presencial)
  cityId      String?  // Referencia a City si el servicio está atado a una ciudad específica
  
  // Pricing
  pricingType PricingType
  basePrice   Int              // Precio base en centavos
  currency    String           @default("GTQ")
  
  // Duración (en minutos)
  durationMin Int?             // Duración mínima
  durationMax Int?             // Duración máxima (si aplica)
  
  // Imágenes
  images      String[]         // Array de URLs
  thumbnail   String?
  
  // Extras y add-ons
  addons      ServiceAddon[]
  
  // Pricing avanzado y reglas de viaje
  pricing     ServicePricing?
  travelRules ServiceTravelRules?
  
  // Disponibilidad y estado
  status      ServiceStatus    @default(ACTIVE)
  isAvailable Boolean          @default(true)
  isFeatured  Boolean          @default(false)
  
  // Qué incluye el servicio
  whatIsIncluded      String[]         // Lista de ítems incluidos (ej: "Equipo de sonido", "Micrófono")

  // Requisitos
  requiresDeposit     Boolean  @default(false)
  depositAmount       Int?     // Monto fijo del depósito en centavos
  depositPercentage   Int?     // O porcentaje del precio
  requiresConsultation Boolean @default(false)
  
  // Políticas
  cancellationPolicy  String?  @db.Text
  termsAndConditions  String?  @db.Text
  
  // SEO
  tags        String[]
  
  // Servicio principal del artista (uno por artista, visible en búsquedas)
  isMainService Boolean  @default(false)

  // Capacidad de personas (para filtrado inteligente)
  minGuests   Int?     // Mínimo de personas para este servicio
  maxGuests   Int?     // Máximo de personas que puede atender

  // Estadísticas
  viewCount   Int      @default(0)
  bookingCount Int     @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([artistId, slug])
  @@index([artistId])
  @@index([categoryId])
  @@index([cityId])
  @@index([status])
  @@index([pricingType])
  @@index([isMainService])
  @@map("services")
}

model ServiceAddon {
  id          String   @id @default(uuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  price       Int              // Precio adicional en centavos
  
  isRequired  Boolean  @default(false) // Si es obligatorio
  isOptional  Boolean  @default(true)
  isDefault   Boolean  @default(false) // Se incluye por default
  
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  
  @@index([serviceId])
  @@map("service_addons")
}

// Modelo para paquetes/combos (múltiples servicios)
model ServicePackage {
  id          String   @id @default(uuid())
  artistId    String   // Artista que ofrece el paquete
  
  name        String
  description String   @db.Text
  
  // Servicios incluidos (array de service IDs)
  serviceIds  String[]
  
  // Pricing del paquete
  originalPrice Int    // Suma de precios individuales
  packagePrice  Int    // Precio con descuento
  savings       Int    // Ahorro calculado
  currency      String @default("GTQ")
  
  // Disponibilidad
  isActive    Boolean  @default(true)
  validFrom   DateTime?
  validUntil  DateTime?
  
  // Imagen
  thumbnail   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([artistId])
  @@index([isActive])
  @@map("service_packages")
}

// Pricing avanzado - Define cómo se calcula el precio del servicio
model ServicePricing {
  id          String       @id @default(uuid())
  serviceId   String       @unique
  service     Service      @relation(fields: [serviceId], references: [id])
  
  pricingModel     PricingModel // Modelo de cálculo
  currency         String       @default("GTQ")
  
  // Precio base (siempre requerido)
  basePriceCents   Int          // Precio base en centavos
  
  // Para BASE_PLUS_HOURLY y PACKAGE
  includedMinutes  Int?         // Minutos incluidos en el precio base
  extraMinutePriceCents Int?    // Precio por minuto adicional en centavos
  
  // Anticipación mínima para reservar
  minNoticeHours   Int?         // Horas mínimas de anticipación
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([serviceId])
  @@map("service_pricing")
}

// Reglas de viaje/desplazamiento del servicio
model ServiceTravelRules {
  id          String   @id @default(uuid())
  serviceId   String   @unique
  service     Service  @relation(fields: [serviceId], references: [id])
  
  // Kilómetros incluidos sin costo adicional
  includedKm  Int?     // null = sin límite gratuito
  
  // Precio por kilómetro adicional
  pricePerKmCents Int? // Costo en centavos
  
  // Distancia máxima permitida
  maxDistanceKm   Int? // null = sin límite
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([serviceId])
  @@map("service_travel_rules")
}

// ============================================================================
// Cities - Sistema formal de ciudades con coordenadas
// ============================================================================

model Country {
  id          String   @id @default(uuid())
  
  // Identificación
  name        String   // Nombre completo
  shortName   String   // Nombre corto (ej: "México", "USA")
  code        String   @unique // Código ISO 3166-1 alpha-2 (ej: "MX", "US")
  code3       String?  // Código ISO 3166-1 alpha-3 (ej: "MEX", "USA")
  
  // Geografía
  continent   String   // "América", "Europa", "Asia", etc.
  region      String?  // Sub-región (ej: "América del Norte")
  
  // Códigos de teléfono
  phoneCode   String   // Código de teléfono (ej: "+52", "+1")
  
  // Moneda
  currency    String   // Código de moneda (ej: "GTQ", "USD")
  currencySymbol String? // Símbolo (ej: "$", "€", "£")
  
  // Idioma
  languages   String[] // Códigos de idiomas (ej: ["es", "en"])
  
  // Estados/provincias
  states      State[]
  
  // Metadata
  isActive    Boolean  @default(true)
  isPopular   Boolean  @default(false) // Para destacar en listas
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([code])
  @@index([isActive, isPopular])
  @@map("countries")
}

model State {
  id          String   @id @default(uuid())
  
  // País
  countryId   String
  country     Country  @relation(fields: [countryId], references: [id])
  
  // Identificación
  name        String   // Nombre completo del estado
  shortName   String?  // Abreviación (ej: "CDMX", "CA")
  code        String   // Código único del estado
  
  // Ciudades
  cities      City[]
  
  // Metadata
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([countryId, code])
  @@index([countryId])
  @@index([code])
  @@map("states")
}

model City {
  id          String   @id @default(uuid())
  
  // Ubicación administrativa
  stateId     String
  state       State    @relation(fields: [stateId], references: [id])
  
  // Identificación
  name        String   // Nombre de la ciudad
  slug        String   @unique // URL-friendly
  
  // Coordenadas (centro de la ciudad)
  latitude    Float
  longitude   Float
  
  // Zona horaria
  timezone    String?  // IANA timezone (ej: "America/Mexico_City")
  
  // Población
  population  Int?     // Número de habitantes
  
  // Clasificación
  isCapital   Boolean  @default(false) // Capital del estado/país
  isMetro     Boolean  @default(false) // Zona metropolitana importante
  
  // Alias y nombres alternativos
  aliases     String[] // Nombres alternativos (ej: "CDMX", "Ciudad de México")
  
  // Metadata
  isActive    Boolean  @default(true)
  isPopular   Boolean  @default(false) // Para destacar en búsquedas
  
  // SEO
  description String?  @db.Text
  image       String?  // URL de imagen representativa
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([stateId, name])
  @@index([stateId])
  @@index([slug])
  @@index([latitude, longitude])
  @@index([isActive, isPopular])
  @@map("cities")
}

// ============================================================================
// Media Assets - Sistema polimórfico de archivos multimedia
// ============================================================================

enum MediaType {
  IMAGE        // Imagen
  VIDEO        // Video
  AUDIO        // Audio
  DOCUMENT     // Documento (PDF, etc.)
  OTHER        // Otro tipo
}

enum MediaEntityType {
  ARTIST       // Portfolio de artista
  SERVICE      // Galería de servicio
  BOOKING      // Evidencia de reserva
  REVIEW       // Fotos de reseña
  DISPUTE      // Evidencia de disputa
  PROFILE      // Foto de perfil/cover
  CATEGORY     // Imagen de categoría
  CERTIFICATION // Certificado escaneado
  OTHER        // Otra entidad
}

enum MediaStatus {
  UPLOADING    // En proceso de subida
  PROCESSING   // Procesando (resize, encoding, etc.)
  READY        // Listo para uso
  FAILED       // Falló el procesamiento
  DELETED      // Marcado como eliminado (soft delete)
}

model MediaAsset {
  id          String   @id @default(uuid())
  
  // Tipo de media
  mediaType   MediaType
  status      MediaStatus @default(UPLOADING)
  
  // Relación polimórfica (qué entidad "posee" este media)
  entityType  MediaEntityType
  entityId    String   // ID de la entidad (artistId, serviceId, bookingId, etc.)
  
  // URLs del archivo
  originalUrl String   // URL del archivo original
  url         String   // URL del archivo procesado/optimizado
  thumbnailUrl String? // URL del thumbnail (para videos/images)
  
  // Metadata del archivo
  filename    String   // Nombre original del archivo
  mimeType    String   // Tipo MIME (image/jpeg, video/mp4, etc.)
  fileSize    Int      // Tamaño en bytes
  
  // Dimensiones (si aplica)
  width       Int?
  height      Int?
  duration    Int?     // Duración en segundos (para video/audio)
  
  // Información adicional
  title       String?
  description String?  @db.Text
  altText     String?  // Texto alternativo para accesibilidad
  
  // Ordenamiento y display
  order       Int      @default(0)
  isFeatured  Boolean  @default(false)
  isPublic    Boolean  @default(true)
  
  // Storage info (para manejo interno)
  storageProvider String? // "s3", "cloudinary", "local", etc.
  storageKey      String? // Key/path en el storage provider
  storageBucket   String? // Bucket name (si aplica)
  
  // Tags y categorización
  tags        String[]
  
  // Metadata adicional (JSON flexible)
  metadata    Json?    // Puede contener: exif data, GPS, color palette, etc.
  
  // Propietario/uploader
  uploadedBy  String   // userId que subió el archivo
  
  // Soft delete
  deletedAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([entityType, entityId])
  @@index([mediaType])
  @@index([status])
  @@index([uploadedBy])
  @@index([entityType, entityId, mediaType])
  @@map("media_assets")
}
