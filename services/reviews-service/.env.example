NODE_ENV=development
PORT=4008

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/piums_reviews?schema=public"

# Auth
JWT_SECRET=your_jwt_secret_here

# Service URLs
BOOKING_SERVICE_URL=http://localhost:4005
NOTIFICATIONS_SERVICE_URL=http://localhost:4006
USERS_SERVICE_URL=http://localhost:4002
ARTISTS_SERVICE_URL=http://localhost:4003

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Review Settings
MAX_PHOTOS_PER_REVIEW=5
MIN_RATING=1
MAX_RATING=5
