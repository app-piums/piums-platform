# Server Config
PORT=4006
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/piums_notifications?schema=public"

# JWT Secret
JWT_SECRET="your_jwt_secret_here"

# Service URLs
AUTH_SERVICE_URL="http://localhost:4001"
USERS_SERVICE_URL="http://localhost:4002"
BOOKING_SERVICE_URL="http://localhost:4005"

# Email Config
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER="noreply@yourdomain.com"
EMAIL_PASSWORD="your_app_password"
EMAIL_FROM="YourApp <noreply@yourdomain.com>"

# SMS Config (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Push Notifications (FCM)
FCM_SERVER_KEY=""

# Features
ENABLE_EMAIL=true
ENABLE_SMS=false
ENABLE_PUSH=false

# Rate Limits
MAX_EMAILS_PER_HOUR=100
MAX_SMS_PER_HOUR=50
