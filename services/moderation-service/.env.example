# Variables de entorno — moderation-service
# Copiar a .env y ajustar valores

# Base de datos
DATABASE_URL="postgresql://piums:piums_dev_password@localhost:5433/piums_moderation"

# Redis (para cache del blacklist)
REDIS_URL="redis://localhost:6379"

# JWT (mismo secret que el resto de servicios)
JWT_SECRET="dev-only-secret-not-for-production"

# Puerto
PORT=4011

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"

# Cache
BLACKLIST_CACHE_TTL_SECONDS=300

# Logging
LOG_LEVEL="debug"

# Strikes config
MAX_STRIKES_BEFORE_RESTRICTION=3
