NODE_ENV=development
PORT=4007

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/piums_payments?schema=public"

# Auth
JWT_SECRET=your_jwt_secret_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Services URLs
BOOKING_SERVICE_URL=http://localhost:4005
NOTIFICATIONS_SERVICE_URL=http://localhost:4006
ARTISTS_SERVICE_URL=http://localhost:4001

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Currency
DEFAULT_CURRENCY=MXN

# Platform Fees (payouts)
PLATFORM_FEE_PERCENTAGE=15
