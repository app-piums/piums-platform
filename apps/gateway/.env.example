# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_CHANGE_IN_PRODUCTION

# CORS Configuration  
# URLs permitidas para CORS (separadas por coma)
# - Client app (piums.com): puerto 3000
# - Artist app (artist.piums.com): puerto 3001  
# - Admin app (admin.piums.com): puerto 3002
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Service URLs (microservices)
AUTH_SERVICE_URL=http://localhost:4001
USERS_SERVICE_URL=http://localhost:4002
ARTISTS_SERVICE_URL=http://localhost:4003
CATALOG_SERVICE_URL=http://localhost:4004
BOOKING_SERVICE_URL=http://localhost:4008
PAYMENTS_SERVICE_URL=http://localhost:4005
REVIEWS_SERVICE_URL=http://localhost:4006
NOTIFICATIONS_SERVICE_URL=http://localhost:4007
SEARCH_SERVICE_URL=http://localhost:4009

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
