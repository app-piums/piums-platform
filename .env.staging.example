# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
POSTGRES_USER=piums
POSTGRES_PASSWORD=your_postgres_password_here

# Database URLs for each service (update with actual credentials)
AUTH_DATABASE_URL=postgresql://piums:password@postgres:5432/piums_auth
USERS_DATABASE_URL=postgresql://piums:password@postgres:5432/piums_users
ARTISTS_DATABASE_URL=postgresql://piums:password@postgres:5432/piums_artists
CATALOG_DATABASE_URL=postgresql://piums:password@postgres:5432/piums_catalog
BOOKING_DATABASE_URL=postgresql://piums:password@postgres:5432/piums_booking
PAYMENTS_DATABASE_URL=postgresql://piums:password@postgres:5432/piums_payments
REVIEWS_DATABASE_URL=postgresql://piums:password@postgres:5432/piums_reviews
NOTIFICATIONS_DATABASE_URL=postgresql://piums:password@postgres:5432/piums_notifications
SEARCH_DATABASE_URL=postgresql://piums:password@postgres:5432/piums_search
CHAT_DATABASE_URL=postgresql://piums:password@postgres:5432/piums_chat

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_PASSWORD=your_redis_password_here
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:your_redis_password_here@redis:6379

# ============================================================================
# JWT & Authentication
# ============================================================================
JWT_SECRET=your_jwt_secret_32_chars_minimum_here
REFRESH_SECRET=your_refresh_secret_32_chars_minimum_here
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# ============================================================================
# CORS & Security
# ============================================================================
ALLOWED_ORIGINS=https://staging.piums.com,https://staging-admin.piums.com
NODE_ENV=staging

# ============================================================================
# Cloudinary (Avatar & Image Uploads)
# ============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================================
# Stripe (Payments)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================================================
# SMTP (Email Notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Piums <noreply@piums.com>

# ============================================================================
# SMS Provider (Optional - Twilio example)
# ============================================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# Push Notifications (Optional - Firebase example)
# ============================================================================
FCM_SERVER_KEY=your_firebase_server_key
FCM_PROJECT_ID=your_firebase_project_id

# ============================================================================
# OAuth (Optional)
# ============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://staging.piums.com/api/auth/google/callback

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=https://staging.piums.com/api/auth/facebook/callback

# ============================================================================
# Service URLs (Internal Communication)
# ============================================================================
AUTH_SERVICE_URL=http://auth-service:4001
USERS_SERVICE_URL=http://users-service:4002
ARTISTS_SERVICE_URL=http://artists-service:4003
CATALOG_SERVICE_URL=http://catalog-service:4004
PAYMENTS_SERVICE_URL=http://payments-service:4005
REVIEWS_SERVICE_URL=http://reviews-service:4006
NOTIFICATIONS_SERVICE_URL=http://notifications-service:4007
BOOKING_SERVICE_URL=http://booking-service:4008
SEARCH_SERVICE_URL=http://search-service:4009
CHAT_SERVICE_URL=http://chat-service:4010

# ============================================================================
# Docker Registry
# ============================================================================
DOCKER_REGISTRY=ghcr.io/app-piums
IMAGE_TAG=staging

# ============================================================================
# Logging & Monitoring (Optional)
# ============================================================================
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=staging

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
